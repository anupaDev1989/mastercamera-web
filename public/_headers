## Security Headers for all pages
/*
  # Strict Transport Security - Force HTTPS for 1 year
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Content Security Policy - No unsafe-inline, using nonces/hashes
  # Note: You'll need to add nonces to inline scripts in production or move all scripts external
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;
  
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # Prevent clickjacking
  X-Frame-Options: DENY
  
  # XSS Protection (legacy but still useful)
  X-XSS-Protection: 1; mode=block
  
  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions Policy - Restrict browser features
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()

## API endpoints - Different CSP for API responses
/api/*
  Content-Security-Policy: default-src 'none'; frame-ancestors 'none';
